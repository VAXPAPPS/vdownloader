#!/usr/bin/make -f

%:
	dh $@ --buildsystem=meson

override_dh_auto_install:
	dh_auto_install
	# Install native messaging host
	install -Dm755 native-messaging/vdl-native-host.py \
		debian/vxap-downloader/usr/lib/vxap-downloader/vdl-native-host.py
	# Chrome native messaging manifest
	install -Dm644 native-messaging/org.vaxp.downloader.chrome.json \
		debian/vxap-downloader/etc/chromium/native-messaging-hosts/org.vaxp.downloader.json
	install -Dm644 native-messaging/org.vaxp.downloader.chrome.json \
		debian/vxap-downloader/etc/opt/chrome/native-messaging-hosts/org.vaxp.downloader.json
	# Firefox native messaging manifest
	install -Dm644 native-messaging/org.vaxp.downloader.firefox.json \
		debian/vxap-downloader/usr/lib/mozilla/native-messaging-hosts/org.vaxp.downloader.json
	# Update paths in manifests
	sed -i 's|/usr/lib/vxap-downloader/vdl-native-host.py|/usr/lib/vxap-downloader/vdl-native-host.py|g' \
		debian/vxap-downloader/etc/chromium/native-messaging-hosts/org.vaxp.downloader.json \
		debian/vxap-downloader/etc/opt/chrome/native-messaging-hosts/org.vaxp.downloader.json \
		debian/vxap-downloader/usr/lib/mozilla/native-messaging-hosts/org.vaxp.downloader.json
	# Install browser extension files
	install -d debian/vxap-downloader/usr/share/vxap-downloader/extension
	cp -r extension/* debian/vxap-downloader/usr/share/vxap-downloader/extension/
